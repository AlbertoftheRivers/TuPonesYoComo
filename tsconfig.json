{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src"],
  "exclude": ["node_modules", "src/lib/i18n.ts", "src/lib/notifications.ts", "src/lib/platform.ts", "src/lib/customCategories.ts", "src/lib/LanguageContext.tsx", "src/lib/recipeTranslation.ts", "src/lib/categoryTranslations.ts"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
